# Local development and production both use PostgreSQL.
# Example providers: Neon, Vercel Postgres, Supabase, Railway Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Optional: direct, non-pooled URL for Prisma CLI migrations. Recommended on Neon.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DB?sslmode=require"

# AI provider: gemini | openai | claude | grok | kimi | mock
# You can also set and switch these in the app Settings UI.
AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Image generation model. Allowed values: gemini-2.5-flash-image (default), gemini-3.1-flash-image-preview
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"

# Optional AI providers
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
ANTHROPIC_API_KEY=""
CLAUDE_API_KEY=""   # alias for ANTHROPIC_API_KEY
CLAUDE_MODEL=""     # e.g. claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
GROK_API_KEY=""
GROK_MODEL=""       # 未指定のとき /v1/models から最新モデルを自動取得
# Grok Imagine 画像生成モデル。OAuth 接続済みなら API 課金なしで使える。
GROK_IMAGE_MODEL="grok-imagine-image-quality"
# Grok 動画生成モデル（Feature E）。
GROK_VIDEO_MODEL="grok-video"
KIMI_API_KEY=""
MOONSHOT_API_KEY="" # alias for KIMI_API_KEY
KIMI_MODEL=""       # e.g. moonshot-v1-128k, moonshot-v1-32k, moonshot-v1-8k

# X OAuth 2.0 PKCE
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_REDIRECT_URI="http://localhost:3003/api/x/callback"
# Add like.read/bookmark.read for sync. Search access may be required for on-demand thread fetching.
X_SCOPES="tweet.read users.read offline.access like.read bookmark.read"
TOKEN_ENCRYPTION_KEY="replace-with-a-long-random-string"

# xAI Grok OAuth (SuperGrok / Premium+). Client ID source:
# NousResearch/hermes-agent hermes_cli/auth.py XAI_OAUTH_CLIENT_ID.
XAI_CLIENT_ID="b1a00492-073a-47ea-816f-4c329264a828"
XAI_REDIRECT_URI="http://127.0.0.1:56121/callback"
# AES-256-GCM key for encrypting XAuth tokens. TOKEN_ENCRYPTION_KEY is also accepted.
XAI_ENCRYPTION_KEY=""
# Vercel Cron authentication secret
CRON_SECRET=""

# Optional. When set, the /api/posts endpoint requires an X-Extension-Token
# header matching this value. Use this on public deployments to keep third
# parties from writing posts via the browser extension. Leave blank for
# personal localhost use.
EXTENSION_TOKEN=""
