# Local development and production both use PostgreSQL.
# Example providers: Neon, Vercel Postgres, Supabase, Railway Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# AI provider: gemini | openai | mock
AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# Optional OpenAI fallback
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# X OAuth 2.0 PKCE
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_REDIRECT_URI="http://localhost:3003/api/x/callback"
# For OAuth connection only, keep the default. Add like.read/bookmark.read when X API permissions allow syncing.
X_SCOPES="tweet.read users.read offline.access"
TOKEN_ENCRYPTION_KEY="replace-with-a-long-random-string"
