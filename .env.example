# Local development and production both use PostgreSQL.
# Example providers: Neon, Vercel Postgres, Supabase, Railway Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Optional: direct, non-pooled URL for Prisma CLI migrations. Recommended on Neon.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DB?sslmode=require"

# AI provider: gemini | openai | claude | grok | kimi | mock
# You can also set and switch these in the app Settings UI.
AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# Optional AI providers
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
CLAUDE_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4-5"
GROK_API_KEY=""
GROK_MODEL="grok-4"
KIMI_API_KEY=""
KIMI_MODEL="kimi-k2-0711-preview"

# X OAuth 2.0 PKCE
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_REDIRECT_URI="http://localhost:3003/api/x/callback"
# Add like.read/bookmark.read for sync. Search access may be required for on-demand thread fetching.
X_SCOPES="tweet.read users.read offline.access like.read bookmark.read"
TOKEN_ENCRYPTION_KEY="replace-with-a-long-random-string"

# Optional. When set, the /api/posts endpoint requires an X-Extension-Token
# header matching this value. Use this on public deployments to keep third
# parties from writing posts via the browser extension. Leave blank for
# personal localhost use.
EXTENSION_TOKEN=""
