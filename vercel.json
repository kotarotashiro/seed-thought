{
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/x-sync",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/enrich",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/grok-refresh",
      "schedule": "0 */6 * * *"
    }
  ]
}
