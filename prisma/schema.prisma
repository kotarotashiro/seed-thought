// SeedThought - Prisma Schema
// DB: PostgreSQL for production and ongoing development

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id              String   @id @default(cuid())
  source          String   @default("user_like") // "user_like" | "user_bookmark" | "user_manual" | "agent_recommend"
  sourcePostId    String?
  sourceUrl       String?
  savedType       String   // "like" | "bookmark" | "manual"
  authorName      String?
  authorUsername   String?
  authorAvatarUrl String?
  text            String
  translatedText  String?
  mediaJson       String?
  urlCardJson          String?
  videoTranscriptText  String?
  postedAt             DateTime?
  savedAt         DateTime @default(now())
  rawJson         String?
  enrichmentStatus String  @default("done") // "pending" | "processing" | "done" | "failed"
  threadFetchedAt  DateTime? // X APIでツリー取得を試みた最終時刻（null=未取得）。子投稿0件でも記録し、再取得（=X API課金）を防ぐ。
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  classification  PostClassification?
  threadPosts      ThreadPost[]
  learningCard     LearningCard?

  @@unique([sourcePostId, savedType])
}

model LearningCard {
  id           String   @id @default(cuid())
  sourcePostId String   @unique
  title        String
  summary      String
  coreInsight  String
  manual       String
  diagramPrompt String
  imagePrompt  String
  outputJson   String
  userMemo     String?
  // 元の投稿を含めた学習内容全体をMarkdownに整形したもの。エクスポート時に生成・上書き保存する（資産としてDBに残す）。
  exportText   String?
  status       String   @default("draft") // "draft" | "saved"
  learningMode      String   @default("content")  // "content" | "format"
  strictLearningJson String?
  // SRS (spaced repetition)
  reviewLevel    Int       @default(0)
  lastReviewedAt DateTime?
  nextDueAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sourcePost Post @relation(fields: [sourcePostId], references: [id], onDelete: Cascade)
  outputs    LearningCardOutput[]
  images     LearningCardImage[]
  videos     LearningCardVideo[]
  collectionItems CollectionItem[]
  drafts     XDraft[]
  patternAsset PatternAsset?
}

// 資産庫: 解読器が抽出した「再利用可能な型」の第一級レコード（SeedThought 2 ステップ2）
// 出所カードが消えても資産は残す（onDelete: SetNull）
model PatternAsset {
  id                String   @id @default(cuid())
  learningCardId    String?  @unique
  sourceKind        String   @default("decode") // "decode"（将来 "manual" 等を追加）
  name              String
  structure         String
  variableSlotsJson String   @default("[]") // JSON array of strings
  transferScope     String
  usageNote         String?
  tagsJson          String   @default("[]") // decode.synthesisTags のコピー。掛け合わせ突合に使う
  status            String   @default("active") // "active" | "archived"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  learningCard LearningCard? @relation(fields: [learningCardId], references: [id], onDelete: SetNull)
}

// 掛け合わせ提案の記録（= 資産庫の「掛け合わせの当たり」の記録を兼ねる）
model SynthesisSuggestion {
  id             String   @id @default(cuid())
  dateKey        String   // JST の "YYYY-MM-DD"
  status         String   @default("proposed") // "proposed" | "accepted" | "dismissed"
  cardAId        String   // LearningCard.id（FK は張らない。カード削除後も記録として残す）
  cardBId        String?  // 素材×素材のとき。素材×型のときは null
  patternAssetId String?  // 素材×型のとき。素材×素材のときは null
  title          String
  angle          String
  reason         String
  takeaway       String
  seedHook       String?
  collectionId   String?  // accept 時に作成した Collection.id
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([dateKey, createdAt])
}

model LearningCardImage {
  id             String   @id @default(cuid())
  learningCardId String
  // "explanation" | "diagram"
  kind           String
  prompt         String
  mimeType       String   @default("image/png")
  dataBase64     String
  createdAt      DateTime @default(now())

  learningCard LearningCard @relation(fields: [learningCardId], references: [id], onDelete: Cascade)

  @@index([learningCardId])
}

model LearningCardVideo {
  id             String   @id @default(cuid())
  learningCardId String
  prompt         String
  status         String   @default("pending") // "pending" | "processing" | "done" | "failed"
  videoId        String?  // xAI job id
  videoUrl       String?
  thumbnailUrl   String?
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  learningCard LearningCard @relation(fields: [learningCardId], references: [id], onDelete: Cascade)

  @@index([learningCardId])
}

model Collection {
  id          String   @id @default(cuid())
  title       String
  description String?
  idea        String?  // user's own ideas/angles to blend with saved posts
  outputJson  String?  // last generated bundled output (e.g. seminar)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CollectionItem[]
}

model CollectionItem {
  id             String   @id @default(cuid())
  collectionId   String
  learningCardId String
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  collection   Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  learningCard LearningCard @relation(fields: [learningCardId], references: [id], onDelete: Cascade)

  @@unique([collectionId, learningCardId])
  @@index([collectionId, order])
}

model LearningCardOutput {
  id             String   @id @default(cuid())
  learningCardId String
  outputType     String   // "x" | "instagram" | "note" | "markdown_log" | "seminar" | "strict_learning"
  title          String
  content        String
  contentJson    String?  // JSON object
  satoriTypeUsed String?  // X媒体のさとり構文の型 "A" | "B" | "C" | "D" | "E"
  createdAt      DateTime @default(now())

  learningCard LearningCard @relation(fields: [learningCardId], references: [id], onDelete: Cascade)

  @@index([learningCardId])
}

model ThreadPost {
  id              String    @id @default(cuid())
  postId          String
  sourcePostId    String
  sourceUrl       String?
  authorName      String?
  authorUsername  String?
  authorAvatarUrl String?
  text            String
  translatedText  String?
  mediaJson       String?
  postedAt        DateTime?
  threadOrder     Int
  rawJson         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, sourcePostId])
  @@index([postId, threadOrder])
}

model PostClassification {
  id                    String   @id @default(cuid())
  postId                String   @unique
  postType              String   // "thought" | "learning" | "output_material" | "unknown"
  primaryCategory       String
  tagsJson              String   // JSON array of strings
  summary               String
  recommendReason       String
  difficultyLevel       String   // "beginner" | "intermediate" | "advanced" | "unknown"
  outputPotentialScore  Int      @default(0)
  learningPotentialScore Int     @default(0)
  thinkingPotentialScore Int     @default(0)
  recommendedMode       String   // "thought_lens" | "learning_lesson" | "unknown"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model XAccount {
  id                    String    @id @default(cuid())
  xUserId               String    @unique
  username              String
  displayName           String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  scopesJson            String    // JSON array
  connectedAt           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  syncRuns XSyncRun[]
}

model XSyncRun {
  id                   String    @id @default(cuid())
  xAccountId           String
  syncType             String    // "likes" | "bookmarks" | "both"
  status               String    @default("running") // "running" | "success" | "failed"
  requestedLimit       Int
  fetchedCount         Int       @default(0)
  insertedCount        Int       @default(0)
  skippedDuplicateCount Int      @default(0)
  errorMessage         String?
  startedAt            DateTime  @default(now())
  finishedAt           DateTime?

  xAccount XAccount @relation(fields: [xAccountId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  valueJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model XDraft {
  id             String    @id @default(cuid())
  learningCardId String?
  content        String    // X post text (may be thread, separated by "---\n")
  status         String    @default("pending") // "pending" | "approved" | "rejected" | "posted"
  postedUrl      String?
  postedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  learningCard LearningCard? @relation(fields: [learningCardId], references: [id], onDelete: SetNull)
}

model ResearchSession {
  id          String   @id @default(cuid())
  query       String
  mode        String   @default("quick")  // "quick" | "deep"
  status      String   @default("done")   // "running" | "done" | "failed"
  answer      String
  sourcesJson String?
  source      String   @default("manual") // "manual" | "watch"
  createdAt   DateTime @default(now())

  @@index([source, createdAt])
}

// Single-row table for xAI OAuth tokens (populated in Phase 5/6 when OAuth is wired up).
// Tokens are stored encrypted with AES-256-GCM using XAI_ENCRYPTION_KEY.
model XAuth {
  id             String    @id @default(cuid())
  accessToken    String    // encrypted
  refreshToken   String?   // encrypted
  expiresAt      DateTime?
  scope          String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
